# Qdrant Vector Database URL (ชี้ไปที่ service ภายใน compose)
QDRANT_URL=http://qdrant:6333

# Embedding Provider (ollama or openai)
EMBEDDING_PROVIDER=ollama

# Embedding Model
# For Ollama: nomic-embed-text, all-minilm, e5-small, e5-large
# For OpenAI: text-embedding-3-small, text-embedding-3-large
EMBEDDING_MODEL=nomic-embed-text

# Ollama URL (ชี้ไปที่ service ภายใน compose)
OLLAMA_URL=http://ollama:11434

# OpenAI API Key (ถ้าใช้ OpenAI)
# OPENAI_API_KEY=your-api-key-here

# Server Configuration
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=production
